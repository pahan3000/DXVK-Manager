  <ItemGroup>
    <!-- NuGet-restored on build: right-click the solution -> Restore NuGet Packages
         if your IDE doesn't do this automatically.

         Newtonsoft.Json.dll MUST be deployed next to DxvkInjector.dll. This project calls
         JsonConvert directly (DxvkGameConfigStore), so the JIT needs to resolve the
         Newtonsoft.Json assembly the moment Detect/Save runs. A previous version of this
         project set ExcludeAssets="runtime" here on the theory that Playnite always has a
         compatible copy already loaded — that assumption doesn't hold reliably (plugin
         assemblies are loaded via LoadFrom, and probing doesn't transparently fall back to
         whatever the host or another plugin happened to load first), and it's exactly what
         produced "Could not load file or assembly 'Newtonsoft.Json...'" on Detect. Shipping
         our own copy is safe: NuGet Newtonsoft.Json 13.0.x all share AssemblyVersion
         13.0.0.0, so whichever copy (Playnite's, ours, or another plugin's) loads into the
         AppDomain first satisfies every other 13.0.x reference without needing a redirect. -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="PlayniteSDK" Version="6.16.0" />
  </ItemGroup>
